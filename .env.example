# ============================================================
# cc-lens Environment Configuration
# Copy this file to .env.local and adjust paths as needed
# ============================================================

# OpenClaw — set if your .openclaw is not at ~/.openclaw
# OPENCLAW_HOME=D:\YourPath\.openclaw

# Codex — set if your .codex is not at ~/.codex
# CODEX_HOME=D:\YourPath\.codex
